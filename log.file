    [properties:WPCF7_ContactForm:private] => Array
        (
            [form] => <strong class="form-title">Зворотній зв’язок</strong>
        <div class="form-field-list">
            <div class="form-field">
                <label class="form-label">Введіть ваше ім’я*</label>
[text* firstname class:form-input autocomplete:name]
            </div>
<div class="form-field">
                <label class="form-label">Введіть прізвище*</label>
[text* lastname class:form-input autocomplete:name]
            </div>
<div class="form-field">
                <label class="form-label">Введіть ваш email*</label>
[tel* phone class:form-input autocomplete:tel]
            </div>
<div class="form-field">
                <label class="form-label">Введіть номер телефону*</label>
[email* email class:form-input autocomplete:email]
            </div>
<div class="form-field form-field-big">
                <label class="form-label">Повідомлення</label>
[text message class:form-input class:form-field-big]
            </div>
            
            
            
            
        </div>
        <button class="button-wrapper header-contact-button">
            [submit  class:form-button class:action-button "Надіслати запит"]
        </button>
        <button type="button" class="form-close feedback-close"></button>
            [mail] => Array
                (
                    [active] => 1
                    [subject] => [_site_title] "[your-subject]"
                    [sender] => [_site_title] <wordpress@pleasure>
                    [recipient] => [_site_admin_email]
                    [body] => Від: [your-name] [your-email]
Тема: [your-subject]

Текст повідомлення:
[your-message]

-- 
This is a notification that a contact form was submitted on your website ([_site_title] [_site_url]).
                    [additional_headers] => Reply-To: [your-email]
                    [attachments] => 
                    [use_html] => 
                    [exclude_blank] => 
                )

            [mail_2] => Array
                (
                    [active] => 
                    [subject] => [_site_title] "[your-subject]"
                    [sender] => [_site_title] <wordpress@pleasure>
                    [recipient] => [your-email]
                    [body] => Текст повідомлення:
[your-message]

-- 
This email is a receipt for your contact form submission on our website ([_site_title] [_site_url]) in which your email address was used. If that was not you, please ignore this message.
                    [additional_headers] => Reply-To: [_site_admin_email]
                    [attachments] => 
                    [use_html] => 
                    [exclude_blank] => 
                )

            [messages] => Array
                (
                    [mail_sent_ok] => Дякуємо за Ваше повідомлення. Воно було надіслане.
                    [mail_sent_ng] => Сталася помилка під час спроби відправити Ваше повідомлення. Будь ласка, спробуйте ще раз пізніше.
                    [validation_error] => Одне або декілька полів містять помилкові дані. Будь ласка, перевірте їх і спробуйте ще раз.
                    [spam] => Сталася помилка під час спроби відправити Ваше повідомлення. Будь ласка, спробуйте ще раз пізніше.
                    [accept_terms] => Ви повинні прийняти умови та положення перед тим, як відправляти Ваше повідомлення.
                    [invalid_required] => Будь ласка, заповніть це поле.
                    [invalid_too_long] => Це поле містить занадто довгі дані.
                    [invalid_too_short] => Це поле містить занадто короткі дані.
                    [upload_failed] => Під час завантаження файлу сталася невідома помилка.
                    [upload_file_type_invalid] => Вам не дозволено завантажувати файли цього типу.
                    [upload_file_too_large] => Завантажений файл завеликий.
                    [upload_failed_php_error] => Під час завантаження файлу сталася помилка.
                    [invalid_date] => Введіть дату у форматі YYYY-MM-DD.
                    [date_too_early] => Це поле має занадто ранню дату.
                    [date_too_late] => Це поле має надто пізню дату.
                    [invalid_number] => Будь ласка, введіть номер.
                    [number_too_small] => Це поле має занадто замалий номер.
                    [number_too_large] => Це поле має занадто великий номер.
                    [quiz_answer_not_correct] => Неправильна відповідь на питання перевірки.
                    [invalid_email] => Будь ласка, введіть адресу електронної пошти.
                    [invalid_url] => Будь ласка, введіть URL.
                    [invalid_tel] => Будь ласка, введіть номер телефону.
                    [captcha_not_match] => Введено невірний контрольний код.
                )

            [additional_settings] => skip_mail: on
        )

