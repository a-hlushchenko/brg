                    [attachments] => 
                    [use_html] => 
                    [exclude_blank] => 
                )

            [messages] => Array
                (
                    [mail_sent_ok] => Дякуємо за Ваше повідомлення. Воно було надіслане.
                    [mail_sent_ng] => Сталася помилка під час спроби відправити Ваше повідомлення. Будь ласка, спробуйте ще раз пізніше.
                    [validation_error] => Одне або декілька полів містять помилкові дані. Будь ласка, перевірте їх і спробуйте ще раз.
                    [spam] => Сталася помилка під час спроби відправити Ваше повідомлення. Будь ласка, спробуйте ще раз пізніше.
                    [accept_terms] => Ви повинні прийняти умови та положення перед тим, як відправляти Ваше повідомлення.
                    [invalid_required] => Будь ласка, заповніть це поле.
                    [invalid_too_long] => Це поле містить занадто довгі дані.
                    [invalid_too_short] => Це поле містить занадто короткі дані.
                    [upload_failed] => Під час завантаження файлу сталася невідома помилка.
                    [upload_file_type_invalid] => Вам не дозволено завантажувати файли цього типу.
                    [upload_file_too_large] => Завантажений файл завеликий.
                    [upload_failed_php_error] => Під час завантаження файлу сталася помилка.
                    [invalid_date] => Введіть дату у форматі YYYY-MM-DD.
                    [date_too_early] => Це поле має занадто ранню дату.
                    [date_too_late] => Це поле має надто пізню дату.
                    [invalid_number] => Будь ласка, введіть номер.
                    [number_too_small] => Це поле має занадто замалий номер.
                    [number_too_large] => Це поле має занадто великий номер.
                    [quiz_answer_not_correct] => Неправильна відповідь на питання перевірки.
                    [invalid_email] => Будь ласка, введіть адресу електронної пошти.
                    [invalid_url] => Будь ласка, введіть URL.
                    [invalid_tel] => Будь ласка, введіть номер телефону.
                    [captcha_not_match] => Введено невірний контрольний код.
                )

            [additional_settings] => skip_mail: on
        )

